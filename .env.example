# Askewly Command cloud mode
# Copy to .env.local for local development. Never commit real values.

SUPABASE_URL=
SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Desktop widget schedule mode. Keep files for legacy local markdown mode.
ASKEWLY_COMMAND_SCHEDULE_MODE=files
ASKEWLY_COMMAND_SUPABASE_ACCESS_TOKEN=
ASKEWLY_COMMAND_WORKSPACE_ID=
ASKEWLY_COMMAND_USER_EMAIL=

# Legacy M4/PWA markdown schedule API. Leave disabled after Supabase cutover.
ASKEWLY_COMMAND_LEGACY_SCHEDULE_ENABLED=0

# Public landing domain safety. Leave private APIs disabled on dashboard.askewly.com.
ASKEWLY_COMMAND_PRIVATE_API_ENABLED=0

GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_SECRET=
GOOGLE_OAUTH_IOS_CLIENT_ID=
GOOGLE_OAUTH_ANDROID_CLIENT_ID=

KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

EXPO_SCHEME=askewlycommand
EXPO_REDIRECT_PATH=auth

# Admin-only credentials such as service-role keys and database passwords are
# intentionally omitted from this public snapshot example. Keep them in local
# operator-only files when running private migration or verification scripts.
