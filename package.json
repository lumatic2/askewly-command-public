{
  "name": "askewly-command",
  "version": "0.1.0",
  "private": true,
  "description": "Askewly Command personal command center: always-on Windows widget, mobile app, and agent-facing CLI on Google Workspace data.",
  "main": "widget/main.js",
  "scripts": {
    "start": "electron ./widget/main.js",
    "start:widget": "electron ./widget/main.js",
    "web:dev": "npm --prefix web run dev --",
    "web:build": "npm --prefix web run build",
    "web:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-public-landing-worker.ps1",
    "web:preview": "npm --prefix web run preview",
    "askewly": "node ./scripts/askewly-command.js",
    "verify:cli-negative-paths": "node ./scripts/verify-cli-negative-paths.js",
    "verify:public-readiness": "node ./scripts/verify-public-readiness.js",
    "verify:google-workspace-dry-run": "node ./scripts/verify-google-workspace-migration-dry-run.js",
    "verify:google-workspace-importer": "node ./scripts/verify-google-workspace-migration-importer.js",
    "verify:google-workspace-importer:e2e": "node ./scripts/verify-google-workspace-importer-e2e.js",
    "verify:google-workspace-command-adapter": "node ./scripts/verify-google-workspace-command-adapter.js",
    "verify:google-workspace-command-adapter:e2e": "node ./scripts/verify-google-workspace-command-adapter-e2e.js",
    "verify:google-sheets-catalog": "node ./scripts/verify-google-sheets-catalog.js",
    "verify:google-sheets-catalog-migrate": "node ./scripts/verify-google-sheets-catalog-migrate.js",
    "verify:google-sheets-projects-routing": "node ./scripts/verify-google-sheets-projects-routing.js",
    "verify:migrate-deadlines-to-calendar": "node ./scripts/verify-migrate-deadlines-to-calendar.js",
    "verify:widget-data-service": "node ./scripts/verify-widget-data-service.js",
    "verify:widget-service-bridge": "node ./scripts/verify-widget-service-bridge.js",
    "verify:widget-crud-ui": "node ./scripts/verify-widget-crud-ui.js",
    "verify:widget-crud-e2e": "node ./scripts/verify-widget-crud-e2e.js",
    "verify:widget-calendar-e2e": "node ./scripts/verify-widget-calendar-e2e.js",
    "install-startup": "powershell -ExecutionPolicy Bypass -File ./scripts/install-startup-shortcut.ps1"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^37.2.0"
  }
}
